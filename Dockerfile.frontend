# Build stage
FROM node:20-alpine as build

WORKDIR /app

# Enable legacy peer deps if needed
ENV NPM_CONFIG_LEGACY_PEER_DEPS=true

COPY frontend/package*.json ./
RUN npm install

COPY frontend/ .
RUN npm run build

# Production stage
FROM nginx:alpine

# Copy built files
COPY --from=build /app/dist /usr/share/nginx/html

# Copy nginx config
COPY production/nginx/conf.d/default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
